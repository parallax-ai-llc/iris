# API Configuration
# Development: use local server
VITE_API_URL=http://localhost:4000
VITE_LLM_URL=http://localhost:8080

# Production: use production API (uncomment for production build)
# VITE_API_URL=https://api.parallax.kr
# VITE_LLM_URL=https://parallax-llm-51831093911.us-east1.run.app

# Environment
NODE_ENV=development

# Windows Code Signing — Azure Trusted Signing
# .env.local에 실제 값을 넣고 절대 커밋하지 말 것
# TRUSTED_SIGNING_ENDPOINT=https://eus.codesigning.azure.net
# TRUSTED_SIGNING_ACCOUNT_NAME=
# TRUSTED_SIGNING_CERT_PROFILE_NAME=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
