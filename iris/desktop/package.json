{
  "name": "iris-desktop",
  "version": "0.14.0",
  "description": "Iris AI Media Generation Desktop App",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:selfhost": "vite --mode selfhost",
    "build": "tsc && vite build && electron-builder",
    "build:selfhost": "tsc && vite build --mode selfhost",
    "build:win": "tsc && vite build && electron-builder --win",
    "build:mac": "tsc && vite build && electron-builder --mac",
    "build:linux": "tsc && vite build && electron-builder --linux",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release:clean": "node -e \"require('fs').rmSync('release',{recursive:true,force:true})\"",
    "release:build": "pnpm release:clean && pnpm lint && tsc && vite build && electron-builder --publish never",
    "release:build:win": "pnpm release:clean && pnpm lint && tsc && vite build && node scripts/build-win.mjs",
    "release:build:mac": "pnpm lint && node scripts/build-mac.mjs",
    "release:build:linux": "pnpm release:clean && pnpm lint && tsc && vite build && electron-builder --linux --publish never",
    "release:upload:dev": "npx ts-node scripts/upload-release.ts --env=dev",
    "release:upload:prod": "npx ts-node scripts/upload-release.ts --env=production",
    "release:mac:dev": "node scripts/release.mjs --target=mac --env=dev",
    "release:mac:prod": "node scripts/release.mjs --target=mac --env=production",
    "release:win:dev": "node scripts/release.mjs --target=win --env=dev",
    "release:win:prod": "node scripts/release.mjs --target=win --env=production",
    "release:linux:dev": "node scripts/release.mjs --target=linux --env=dev",
    "release:linux:prod": "node scripts/release.mjs --target=linux --env=production",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "test:e2e:build": "tsc && vite build && playwright test --config e2e/playwright.config.ts --headed"
  },
  "keywords": [
    "iris",
    "ai",
    "media",
    "generation",
    "electron"
  ],
  "author": "Parallax AI",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^6.12.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.1",
    "ag-psd": "^30.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "fastify": "^4.29.1",
    "ffmpeg-static": "5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "i18next": "^25.8.17",
    "iris-editor": "workspace:*",
    "iris-engine": "workspace:*",
    "iris-host-local": "workspace:*",
    "iris-nodes": "workspace:*",
    "iris-templates": "workspace:*",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.6",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rollup": "^4.24.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@google-cloud/storage": "^7.19.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "electron": "40.8.0",
    "electron-builder": "26.8.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.19",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.parallax.iris-desktop",
    "productName": "Iris",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/node_modules/**/.v8-cache/**",
      "!**/node_modules/**/test/**",
      "!**/node_modules/**/tests/**",
      "!**/node_modules/**/*.{md,markdown}",
      "!**/node_modules/**/*.map"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://storage.googleapis.com/parallax-ai-images/production/releases/"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "differentialPackage": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "include": "installer/custom.nsh",
      "artifactName": "Iris-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      },
      "format": "UDZO"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png"
    }
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.59.0"
  }
}
