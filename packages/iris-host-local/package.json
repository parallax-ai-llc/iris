{
  "name": "iris-host-local",
  "version": "0.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Open-source local host for the Iris workflow engine. Run `npx iris-flow` to launch a local server, build workflows in the browser, and execute them with your own AI API keys (BYOK). No server, database, GCS, or billing required.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "iris-flow": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./daemon": {
      "import": "./dist/daemon.js",
      "default": "./dist/daemon.js"
    }
  },
  "files": [
    "dist",
    "src",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^6.12.0",
    "croner": "^9.1.0",
    "fastify": "^4.29.1",
    "iris-editor": "workspace:*",
    "iris-engine": "workspace:*",
    "iris-nodes": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
