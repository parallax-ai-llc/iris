# iris-flow — bring your own API keys (BYOK).
# Copy this file to `.env` (same directory you run `npx iris-flow` from, or
# ~/.iris-flow/.env) and fill in only the providers you use. `.env` is yours —
# keep it out of version control. The engine reads these from the environment.

# ── LLM / text ──────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
DEEPSEEK_API_KEY=

# ── Image / video / audio ───────────────────────────────────
STABILITY_API_KEY=
REPLICATE_API_KEY=
IDEOGRAM_API_KEY=
RECRAFT_API_KEY=
RUNWAY_API_KEY=
LUMA_API_KEY=
PIKA_API_KEY=
ELEVENLABS_API_KEY=
SUNO_API_KEY=

# ── Optional server settings ────────────────────────────────
# PORT=4747
# IRIS_FLOW_HOST=127.0.0.1
# IRIS_FLOW_DATA_DIR=
# IRIS_FLOW_NO_OPEN=1
