# pnpm workspace settings
# shamefully-hoist=true keeps node_modules flat at the workspace root for
# tools (Electron builders, Expo/RN Metro, some Next.js plugins) that don't
# follow the strict pnpm node_modules layout.
shamefully-hoist=true
# Auto-install peer deps to match yarn/npm behavior.
auto-install-peers=true
# Allow workspace packages to be linked with `link-workspace-packages=true`.
link-workspace-packages=true
# Skip postinstall scripts only for packages explicitly listed in dangerous-postinstalls (none here).
# strict-peer-dependencies stays default (false) — many React deps emit warnings we don't need to block on.
